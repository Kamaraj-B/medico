NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3001
# Base URL for upload links (e.g. profile images). Use server public URL in Docker.
API_BASE_URL=http://localhost:3000

# Database
MONGODB_URL=mongodb://localhost:27017/medico

# Google Login (redirect flow; add this exact URL to Google Cloud Console → Credentials → Authorized redirect URIs)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
ADMIN_EMAILS=kamaraj.developer@gmail.com
DOCTOR_EMAILS=kamaraj.balakrishnan.ext@veolia.com

# JWT
JWT_SECRET=your_jwt_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Email
EMAIL_SERVICE=gmail
EMAIL_USERNAME=your_email
EMAIL_PASSWORD=your_app_password

# Google Calendar (optional)
GOOGLE_CALENDAR_SYNC_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata
